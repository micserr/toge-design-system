{
  "name": "@jefmari/design-system-next",
  "private": false,
  "version": "1.0.1",
  "main": "./dist/design-system-next.js",
  "module": "./dist/design-system-next.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JefMari/design-system-next.git"
  },
  "type": "module",
  "files": [
    "dist",
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/design-system-next.js",
      "require": "./dist/design-system-next.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --emitDeclarationOnly && vite build",
    "types": "vue-tsc",
    "preview": "vite preview",
    "lint:script": "eslint \"**/*.{js,ts,vue}\" --ignore-pattern \"dist\"",
    "lint:style": "stylelint \"**/*.{vue,css}\"",
    "fix:style": "stylelint --fix \"**/*.{vue,css}\"",
    "lint": "npm run lint:script && npm run lint:style",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@eslint/js": "^9.10.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "stylelint": "^16.9.0",
    "stylelint-config-recess-order": "^5.1.0",
    "stylelint-config-recommended": "^14.0.1",
    "stylelint-config-recommended-vue": "^1.5.0",
    "typescript-eslint": "^8.5.0",
    "vite-plugin-lib-inject-css": "^2.1.1",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@stylistic/stylelint-plugin": "^3.0.1",
    "@types/node": "^22.5.4",
    "@types/vue": "^2.0.0",
    "@vitejs/plugin-vue": "^5.1.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.10.0",
    "eslint-plugin-vue": "^9.28.0",
    "rollup-plugin-gzip": "^4.0.1",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.6.0",
    "unplugin-vue-components": "^0.27.4",
    "vite": "^5.4.3",
    "vite-plugin-dts": "^4.2.1",
    "vite-tsconfig-paths": "^5.0.1",
    "vue-tsc": "^2.1.6"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  }
}
