{
  "name": "design-system-next",
  "private": false,
  "version": "1.0.13",
  "main": "./dist/design-system-next.js",
  "module": "./dist/design-system-next.js",
  "repository": {
    "type": "git",
    "url": "git+https://dev.azure.com/sproutphil/Sprout%20Design%20System/_git/Sprout%20Design%20System%20Next"
  },
  "type": "module",
  "files": [
    "dist",
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/design-system-next.js",
      "require": "./dist/design-system-next.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "types": "vue-tsc",
