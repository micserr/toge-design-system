    "typescript-eslint": "^8.3.0",
    "vue": "^3.4.37"
  },
  "devDependencies": {
    "@stylistic/stylelint-plugin": "^3.0.1",
    "@types/node": "^22.5.0",
    "@vitejs/plugin-vue": "^5.1.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.9.0",
    "eslint-plugin-vue": "^9.27.0",
    "tailwindcss": "^3.4.10",
